{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": null,
  "width": "container",
  "height": 320,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "background": "#F1F5F4",
  "data": {
    "url": "data/vista_purpose.csv"
  },
  "transform": [
    {
      "filter": "datum.trippurp != 'At Home' && datum.trippurp != 'Change Mode' && datum.trippurp != 'Unknown Purpose (at start of day)' && datum.trippurp != 'Other Purpose'"
    },
    {
      "filter": "indexof(['Public transport','School transport','Car','Active transport','Other motorised','Other'], datum.mode_group) >= 0"
    },
    {
      "impute": "percentage",
      "key": "mode_group",
      "keyvals": [
        "Public transport",
        "School transport",
        "Car",
        "Active transport",
        "Other motorised",
        "Other"
      ],
      "groupby": [
        "trippurp"
      ],
      "value": 0
    },
    {
      "impute": "weighted_trips",
      "key": "mode_group",
      "keyvals": [
        "Public transport",
        "School transport",
        "Car",
        "Active transport",
        "Other motorised",
        "Other"
      ],
      "groupby": [
        "trippurp"
      ],
      "value": 0
    },
    {
      "calculate": "isValid(datum.weighted_trips) ? datum.weighted_trips : 0",
      "as": "weighted_trips_filled"
    }
  ],
  "encoding": {
    "x": {
      "field": "mode_group",
      "type": "nominal",
      "title": "Mode group",
      "sort": [
        "Public transport",
        "School transport",
        "Car",
        "Active transport",
        "Other motorised",
        "Other"
      ],
      "axis": {
        "labelAngle": 0,
        "labelPadding": 5
      }
    },
    "y": {
      "field": "trippurp",
      "type": "nominal",
      "title": "Trip purpose",
      "sort": [
        "Work Related",
        "Education",
        "Social",
        "Recreational",
        "Buy Something",
        "Personal Business",
        "Accompany Someone",
        "Pick-up or Drop-off Someone",
        "Pick-up or Deliver Something"
      ]
    }
  },
  "layer": [
    {
      "mark": {
        "type": "rect",
        "stroke": "#F8FAF7",
        "strokeWidth": 1.1
      },
      "encoding": {
        "color": {
          "field": "percentage",
          "type": "quantitative",
          "title": "Trip share (%)",
          "scale": {
            "type": "threshold",
            "domain": [
              5,
              15,
              30,
              50,
              70
            ],
            "range": [
              "#BFDDEA",
              "#8FC3DC",
              "#5EA2CB",
              "#2E7FB8",
              "#0F5B99",
              "#08306B"
            ]
          },
          "legend": {
            "orient": "top",
            "direction": "horizontal",
            "gradientLength": 220,
            "gradientThickness": 14
          }
        },
        "tooltip": [
          {
            "field": "trippurp",
            "type": "nominal",
            "title": "Trip purpose"
          },
          {
            "field": "mode_group",
            "type": "nominal",
            "title": "Mode group"
          },
          {
            "field": "percentage",
            "type": "quantitative",
            "title": "Trip share (%)",
            "format": ".1f"
          },
          {
            "field": "weighted_trips_filled",
            "type": "quantitative",
            "title": "Weighted trips",
            "format": ",.0f"
          }
        ]
      }
    }
  ],
  "config": {
    "font": "Source Sans 3, sans-serif",
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Source Sans 3, sans-serif",
      "titleFont": "Source Sans 3, sans-serif",
      "labelFontSize": 15,
      "titleFontSize": 16,
      "gridColor": "#E3E8E4",
      "domainColor": "#A8B0AC",
      "tickColor": "#A8B0AC",
      "labelColor": "#1F2728",
      "titleColor": "#1F2728"
    },
    "legend": {
      "labelFont": "Source Sans 3, sans-serif",
      "titleFont": "Source Sans 3, sans-serif",
      "labelFontSize": 15,
      "titleFontSize": 16,
      "orient": "bottom",
      "direction": "horizontal"
    }
  }
}
