{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": null,
  "width": "container",
  "height": 360,
  "padding": {
    "left": 16,
    "right": 38,
    "top": 12,
    "bottom": 12
  },
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "background": "transparent",
  "data": {
    "url": "data/tourism_region_access.csv"
  },
  "layer": [
    {
      "mark": {
        "type": "circle",
        "opacity": 0.8,
        "stroke": "white",
        "strokeWidth": 1
      },
      "encoding": {
        "x": {
          "field": "distance_km",
          "type": "quantitative",
          "title": "Distance to nearest regional train station (km)",
          "scale": {
            "domain": [
              -1,
              60
            ]
          },
          "axis": {
            "grid": true,
            "gridColor": "#E3E8E4",
            "titlePadding": 8
          }
        },
        "y": {
          "field": "stations_within_50km",
          "type": "quantitative",
          "title": "Regional train stations within 50 km",
          "scale": {
            "domain": [
              -6,
              66
            ]
          },
          "axis": {
            "grid": true,
            "gridColor": "#E3E8E4",
            "titlePadding": 12,
            "values": [
              0,
              10,
              20,
              30,
              40,
              50,
              60
            ]
          }
        },
        "size": {
          "field": "stations_within_100km",
          "type": "quantitative",
          "title": "Stations within 100 km",
          "scale": {
            "range": [
              60,
              900
            ]
          },
          "legend": null
        },
        "color": {
          "field": "access_category",
          "type": "nominal",
          "title": "Rail access",
          "scale": {
            "domain": [
              "Good",
              "Moderate",
              "Limited"
            ],
            "range": [
              "#0072B2",
              "#8D989D",
              "#D55E00"
            ]
          },
          "legend": {
            "orient": "bottom",
            "direction": "horizontal",
            "titleAnchor": "start"
          }
        },
        "tooltip": [
          {
            "field": "region",
            "type": "nominal",
            "title": "Tourism region"
          },
          {
            "field": "distance_km",
            "type": "quantitative",
            "title": "Nearest-station distance (km)",
            "format": ".1f"
          },
          {
            "field": "stations_within_50km",
            "type": "quantitative",
            "title": "Stations within 50 km"
          },
          {
            "field": "stations_within_100km",
            "type": "quantitative",
            "title": "Stations within 100 km"
          },
          {
            "field": "access_category",
            "type": "nominal",
            "title": "Rail access"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.distance_km <= 35 && datum.region != 'Melbourne' && datum.region != 'Geelong and the Bellarine' && datum.region != 'Murray' && datum.region != 'Goldfields' && datum.region != 'Gippsland'"
        },
        {
          "calculate": "datum.region == 'Yarra Valley and Dandenong Ranges' ? 'Yarra/Dandenong' : datum.region == 'Daylesford and Macedon Ranges' ? 'Daylesford/Mac.' : datum.region == 'Mornington Peninsula' ? 'Mornington' : datum.region == 'Geelong and the Bellarine' ? 'Geelong' : datum.region == 'Great Ocean Road' ? 'Great Ocean Rd' : datum.region",
          "as": "short_region"
        }
      ],
      "mark": {
        "type": "text",
        "font": "Source Sans 3, sans-serif",
        "fontSize": 12,
        "dx": 7,
        "dy": -6,
        "align": "left",
        "color": "#3D4648"
      },
      "encoding": {
        "x": {
          "field": "distance_km",
          "type": "quantitative"
        },
        "y": {
          "field": "stations_within_50km",
          "type": "quantitative"
        },
        "text": {
          "field": "short_region",
          "type": "nominal"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.region == 'Melbourne'"
        },
        {
          "calculate": "'Melbourne'",
          "as": "short_region"
        }
      ],
      "mark": {
        "type": "text",
        "font": "Source Sans 3, sans-serif",
        "fontSize": 12,
        "dx": 10,
        "dy": -10,
        "align": "left",
        "baseline": "bottom",
        "color": "#3D4648"
      },
      "encoding": {
        "x": {
          "field": "distance_km",
          "type": "quantitative"
        },
        "y": {
