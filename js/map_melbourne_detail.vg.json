{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": null,
  "width": "container",
  "height": 400,
  "autosize": {"type": "fit", "contains": "padding"},
  "background": "transparent",
  "config": {
    "font": "Source Sans 3, sans-serif",
    "view": {"stroke": null},
    "legend": {
      "labelFont": "Source Sans 3, sans-serif",
      "titleFont": "Source Sans 3, sans-serif",
      "labelFontSize": 11,
      "titleFontSize": 12,
      "symbolSize": 50,
      "orient": "bottom-left",
      "direction": "vertical",
      "offset": 5,
      "padding": 6,
      "fillColor": "rgba(246,245,240,0.85)",
      "strokeColor": "#C8C3B8",
      "cornerRadius": 4
    }
  },
  "projection": {
    "type": "equirectangular",
    "center": [144.96, -37.81],
    "scale": 38000
  },
  "params": [
    {
      "name": "mode_select",
      "bind": {
        "input": "select",
        "options": [null, "METRO TRAIN", "METRO TRAM", "METRO BUS", "REGIONAL TRAIN", "REGIONAL BUS", "REGIONAL COACH", "INTERSTATE TRAIN", "SKYBUS"],
        "labels": ["Show All Modes", "Metro Train", "Metro Tram", "Metro Bus", "Regional Train", "Regional Bus", "Regional Coach", "Interstate Train", "Skybus"],
        "name": "Transport Mode "
      }
    }
  ],
  "layer": [
    {
      "data": {
        "url": "data/vic_lga_2021.topojson",
        "format": {"type": "topojson", "feature": "LGA_2021_AUST_GDA2020"}
      },
      "mark": {
        "type": "geoshape",
        "fill": "#E0DAC8",
        "stroke": "#F6F5F0",
        "strokeWidth": 0.8
      }
    },
    {
      "data": {"url": "data/pt_stops.csv"},
      "transform": [
        {"filter": "mode_select == null || datum.MODE == mode_select"},
        {
          "calculate": "indexof(datum.MODE, 'TRAIN') >= 0 || datum.MODE == 'INTERSTATE TRAIN' ? 'Train' : indexof(datum.MODE, 'TRAM') >= 0 ? 'Tram' : indexof(datum.MODE, 'BUS') >= 0 ? 'Bus' : 'Regional'",
          "as": "MODE_GROUP"
        }
      ],
      "mark": {
        "type": "circle",
        "opacity": 0.8,
        "strokeWidth": 0
      },
      "encoding": {
        "longitude": {"field": "LONGITUDE", "type": "quantitative"},
        "latitude": {"field": "LATITUDE", "type": "quantitative"},
        "size": {
          "condition": {"test": "mode_select != null", "value": 18},
          "value": 8
        },
        "color": {
          "field": "MODE_GROUP",
          "type": "nominal",
          "title": "Mode",
          "scale": {
            "domain": ["Train", "Tram", "Bus", "Regional"],
            "range": ["#004B87", "#78BE20", "#F58220", "#7B2D8E"]
          }
        },
        "order": {
          "field": "MODE_GROUP",
          "type": "nominal",
          "sort": ["Bus", "Regional", "Tram", "Train"]
        },
        "tooltip": [
          {"field": "STOP_NAME", "type": "nominal", "title": "Stop"},
          {"field": "MODE", "type": "nominal", "title": "Mode"}
        ]
      }
    }
  ]
}