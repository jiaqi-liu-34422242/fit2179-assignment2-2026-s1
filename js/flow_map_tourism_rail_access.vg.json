{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": null,
  "width": "container",
  "height": 460,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "background": "transparent",
  "projection": {
    "type": "equirectangular",
    "center": [145.2, -37.45],
    "scale": 4300
  },
  "layer": [
    {
      "data": {
        "url": "data/vic_lga_2021.topojson",
        "format": {
          "type": "topojson",
          "feature": "LGA_2021_AUST_GDA2020"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#E0DAC8",
        "stroke": "#F6F5F0",
        "strokeWidth": 0.8
      }
    },
    {
      "data": {
        "url": "data/tourism_region_access.csv"
      },
      "mark": {
        "type": "rule",
        "strokeWidth": 2.2,
        "opacity": 0.84
      },
      "encoding": {
        "longitude": {
          "field": "longitude",
          "type": "quantitative"
        },
        "latitude": {
          "field": "latitude",
          "type": "quantitative"
        },
        "longitude2": {
          "field": "station_longitude"
        },
        "latitude2": {
          "field": "station_latitude"
        },
        "color": {
          "field": "access_category",
          "type": "nominal",
          "title": "Rail access",
          "scale": {
            "domain": ["Good", "Moderate", "Limited"],
            "range": ["#2E7D32", "#D59A00", "#C62828"]
          }
        },
        "tooltip": [
          {
            "field": "region",
            "type": "nominal",
            "title": "Tourism region"
          },
          {
            "field": "nearest_station",
            "type": "nominal",
            "title": "Nearest station"
          },
          {
            "field": "distance_km",
            "type": "quantitative",
            "title": "Distance (km)",
            "format": ".1f"
          },
          {
            "field": "access_category",
            "type": "nominal",
            "title": "Rail access"
          }
        ]
      }
    },
    {
      "data": {
        "url": "data/tourism_region_access.csv"
      },
      "mark": {
        "type": "circle",
        "filled": true,
        "size": 115,
        "color": "#004B87",
        "stroke": "white",
        "strokeWidth": 1.2
      },
      "encoding": {
        "longitude": {
          "field": "longitude",
          "type": "quantitative"
        },
        "latitude": {
          "field": "latitude",
          "type": "quantitative"
        },
        "tooltip": [
          {
            "field": "region",
            "type": "nominal",
            "title": "Tourism region"
          },
          {
            "field": "nearest_station",
            "type": "nominal",
            "title": "Nearest station"
          },
          {
            "field": "distance_km",
            "type": "quantitative",
            "title": "Distance (km)",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "data": {
        "url": "data/tourism_region_access.csv"
      },
      "mark": {
        "type": "point",
        "filled": true,
        "shape": "triangle",
        "size": 95,
        "color": "#1B1B1B",
        "stroke": "white",
        "strokeWidth": 0.9
      },
      "encoding": {
        "longitude": {
          "field": "station_longitude",
          "type": "quantitative"
        },
        "latitude": {
          "field": "station_latitude",
          "type": "quantitative"
        },
        "tooltip": [
          {
            "field": "nearest_station",
            "type": "nominal",
            "title": "Nearest station"
          },
          {
            "field": "region",
            "type": "nominal",
            "title": "Connected tourism region"
          }
        ]
      }
    },
    {
      "data": {
        "url": "data/tourism_region_access.csv"
      },
      "mark": {
        "type": "text",
        "font": "Source Sans 3, sans-serif",
        "fontSize": 10,
        "fontWeight": 600,
        "align": "left",
        "baseline": "middle",
        "dx": 7,
        "color": "#3F3F3F"
      },
      "encoding": {
        "longitude": {
          "field": "longitude",
          "type": "quantitative"
        },
        "latitude": {
          "field": "latitude",
          "type": "quantitative"
        },
        "text": {
          "field": "region",
          "type": "nominal"
        }
      }
    }
  ],
  "config": {
    "font": "Source Sans 3, sans-serif",
    "view": {
      "stroke": null
    },
    "legend": {
      "labelFont": "Source Sans 3, sans-serif",
      "titleFont": "Source Sans 3, sans-serif",
      "labelFontSize": 11,
      "titleFontSize": 12,
      "orient": "bottom",
      "direction": "horizontal"
    }
  }
}
