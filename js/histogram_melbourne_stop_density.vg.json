{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": null,
  "width": "container",
  "height": 360,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "background": "transparent",
  "data": {
    "url": "data/melbourne_lga_stop_density.topojson",
    "format": {
      "type": "topojson",
      "feature": "LGA_2021_AUST_GDA2020"
    }
  },
  "mark": {
    "type": "bar",
    "color": "#004B87",
    "cornerRadiusEnd": 2,
    "opacity": 0.92
  },
  "encoding": {
    "x": {
      "field": "properties.stops_per_sqkm",
      "type": "quantitative",
      "bin": {
        "maxbins": 9
      },
      "title": "Stops per square kilometre",
      "axis": {
        "grid": false
      }
    },
    "y": {
      "aggregate": "count",
      "type": "quantitative",
      "title": "Number of LGAs",
      "axis": {
        "grid": true,
        "tickMinStep": 1
      }
    },
    "tooltip": [
      {
        "field": "properties.stops_per_sqkm",
        "type": "quantitative",
        "bin": true,
        "title": "Stop-density bin"
      },
      {
        "aggregate": "count",
        "type": "quantitative",
        "title": "LGAs"
      }
    ]
  },
  "config": {
    "font": "Source Sans 3, sans-serif",
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Source Sans 3, sans-serif",
      "titleFont": "Source Sans 3, sans-serif",
      "labelFontSize": 11,
      "titleFontSize": 12,
      "gridColor": "#E8E4DB",
      "domainColor": "#9A968D",
      "tickColor": "#9A968D",
      "labelColor": "#1B1B1B",
      "titleColor": "#1B1B1B"
    }
  }
}
