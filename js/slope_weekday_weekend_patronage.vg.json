{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": null,
  "width": "container",
  "height": 315,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "background": "transparent",
  "data": {
    "url": "data/weekday_weekend_patronage_2025.csv"
  },
  "encoding": {
    "x": {
      "field": "Day_type",
      "type": "ordinal",
      "title": null,
      "sort": [
        "Normal Weekday",
        "Weekend"
      ],
      "axis": {
        "labelAngle": 0,
        "labelFontWeight": 600,
        "domain": false,
        "tickSize": 0
      }
    },
    "y": {
      "field": "avg_daily_patronage_thousands",
      "type": "quantitative",
      "title": "Average daily patronage (thousands)",
      "scale": {
        "zero": true
      },
      "axis": {
        "grid": true
      }
    },
    "color": {
      "field": "mode_label",
      "type": "nominal",
      "title": "Mode",
      "scale": {
        "domain": [
          "Metro train",
          "Tram",
          "Metro bus",
          "Regional train",
          "Regional bus"
        ],
        "range": [
          "#0072B2",
          "#CC79A7",
          "#D55E00",
          "#8D989D",
          "#595959"
        ]
      },
      "legend": {
        "orient": "bottom",
        "direction": "horizontal"
      }
    },
    "tooltip": [
      {
        "field": "mode_label",
        "type": "nominal",
        "title": "Mode"
      },
      {
        "field": "Day_type",
        "type": "nominal",
        "title": "Day type"
      },
      {
        "field": "avg_daily_patronage",
        "type": "quantitative",
        "title": "Average daily patronage",
        "format": ",.0f"
      }
    ]
  },
  "layer": [
    {
      "mark": {
        "type": "line",
        "strokeWidth": 2.5
      },
      "encoding": {
        "detail": {
          "field": "mode_label",
          "type": "nominal"
        },
        "strokeDash": {
          "field": "mode_label",
          "type": "nominal",
          "scale": {
            "domain": [
              "Metro train",
              "Tram",
              "Metro bus",
              "Regional train",
              "Regional bus"
            ],
            "range": [
              [],
              [
                6,
                3
              ],
              [
                2,
                3
              ],
              [
                9,
                3
              ],
              [
                4,
                4
              ]
            ]
          }
        }
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 105,
        "stroke": "#F8FAF7",
        "strokeWidth": 1.5
      }
    },
    {
      "transform": [
        {
          "filter": "datum.Day_type == 'Weekend'"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 8,
        "font": "Source Sans 3, sans-serif",
        "fontSize": 14,
        "fontWeight": 600
      },
      "encoding": {
        "text": {
          "field": "mode_label",
          "type": "nominal"
        }
      }
    }
  ],
  "config": {
    "font": "Source Sans 3, sans-serif",
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Source Sans 3, sans-serif",
      "titleFont": "Source Sans 3, sans-serif",
      "labelFontSize": 15,
      "titleFontSize": 16,
      "gridColor": "#E3E8E4",
      "domainColor": "#A8B0AC",
      "tickColor": "#A8B0AC",
      "labelColor": "#1F2728",
      "titleColor": "#1F2728"
    },
    "legend": {
      "labelFont": "Source Sans 3, sans-serif",
      "titleFont": "Source Sans 3, sans-serif",
      "labelFontSize": 15,
      "titleFontSize": 16
    }
  }
}
