{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": null,
  "width": "container",
  "height": 340,
  "autosize": {"type": "fit", "contains": "padding"},
  "background": "transparent",
  "data": {
    "url": "data/pt_stops.csv"
  },
  "transform": [
    {
      "calculate": "indexof(datum.MODE, 'TRAIN') >= 0 || datum.MODE == 'INTERSTATE TRAIN' ? 'Train' : indexof(datum.MODE, 'TRAM') >= 0 ? 'Tram' : indexof(datum.MODE, 'BUS') >= 0 ? 'Bus' : 'Regional'",
      "as": "MODE_GROUP"
    }
  ],
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 3
  },
  "encoding": {
    "y": {
      "field": "MODE",
      "type": "nominal",
      "sort": "-x",
      "title": null,
      "axis": {"labelFontSize": 11}
    },
    "x": {
      "aggregate": "count",
      "type": "quantitative",
      "title": "Number of stops",
      "axis": {"grid": true, "gridColor": "#E8E4DB"}
    },
    "color": {
      "field": "MODE_GROUP",
      "type": "nominal",
      "title": "Mode",
      "legend": null,
      "scale": {
        "domain": ["Train", "Tram", "Bus", "Regional"],
        "range": ["#004B87", "#78BE20", "#F58220", "#7B2D8E"]
      }
    },
    "tooltip": [
      {"field": "MODE", "type": "nominal", "title": "Mode"},
      {"aggregate": "count", "type": "quantitative", "title": "Stops"}
    ]
  },
  "config": {
    "font": "Source Sans 3, sans-serif",
    "view": {"stroke": null},
    "axis": {
      "labelFont": "Source Sans 3, sans-serif",
      "titleFont": "Source Sans 3, sans-serif",
      "labelFontSize": 11,
      "titleFontSize": 12
    }
  }
}