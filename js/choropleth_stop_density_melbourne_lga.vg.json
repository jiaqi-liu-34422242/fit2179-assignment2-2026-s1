{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": null,
  "width": "container",
  "height": 400,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "background": "#F1F5F4",
  "projection": {
    "type": "equirectangular",
    "center": [
      145.1,
      -37.88
    ],
    "scale": 18000
  },
  "data": {
    "url": "data/melbourne_lga_stop_density.topojson",
    "format": {
      "type": "topojson",
      "feature": "LGA_2021_AUST_GDA2020"
    }
  },
  "params": [
    {
      "name": "mode_select",
      "value": "Total",
      "bind": {
        "input": "select",
        "name": "Transport mode: ",
        "options": [
          "Total",
          "Bus",
          "Train",
          "Tram",
          "Regional"
        ]
      }
    },
    {
      "name": "lga_select",
      "select": {
        "type": "point",
        "fields": [
          "properties.LGA_NAME21"
        ],
        "on": "click",
        "clear": "dblclick"
      }
    },
    {
      "name": "lga_hover",
      "select": {
        "type": "point",
        "fields": [
          "properties.LGA_NAME21"
        ],
        "on": "pointerover",
        "clear": "pointerout"
      }
    }
  ],
  "transform": [
    {
      "calculate": "mode_select == 'Total' ? datum.properties.stops_count : datum.properties[mode_select]",
      "as": "selected_stops"
    },
    {
      "calculate": "mode_select",
      "as": "selected_mode"
    },
    {
      "calculate": "datum.selected_stops / datum.properties.AREASQKM21",
      "as": "selected_density"
    }
  ],
  "mark": {
    "type": "geoshape",
    "cursor": "pointer"
  },
  "encoding": {
    "color": {
      "field": "selected_density",
      "type": "quantitative",
      "title": "Stops per km²",
      "scale": {
        "type": "threshold",
        "domain": [
          2,
          6,
          10,
          14,
          18
        ],
        "range": [
          "#BFDDEA",
          "#8FC3DC",
          "#5EA2CB",
          "#2E7FB8",
          "#0F5B99",
          "#08306B"
        ]
      },
      "legend": {
        "orient": "right",
        "gradientLength": 220
      }
    },
    "stroke": {
      "condition": [
        {
          "param": "lga_select",
          "empty": false,
          "value": "#1F2728"
        },
        {
          "param": "lga_hover",
          "empty": false,
          "value": "#D55E00"
        }
      ],
      "value": "#526368"
    },
    "strokeWidth": {
      "condition": [
        {
          "param": "lga_select",
          "empty": false,
          "value": 2.6
        },
        {
          "param": "lga_hover",
          "empty": false,
          "value": 2
        }
      ],
      "value": 1.1
    },
    "opacity": {
      "condition": {
        "param": "lga_select",
        "empty": false,
        "value": 1
      },
      "value": 1
    },
    "tooltip": [
      {
        "field": "properties.LGA_NAME21",
        "type": "nominal",
        "title": "LGA"
      },
      {
        "field": "selected_mode",
        "type": "nominal",
        "title": "Selected mode"
      },
      {
        "field": "selected_stops",
        "type": "quantitative",
        "title": "Selected stops",
        "format": ",.0f"
      },
      {
        "field": "selected_density",
        "type": "quantitative",
        "title": "Selected stops per km²",
        "format": ".2f"
      },
      {
        "field": "properties.stops_count",
        "type": "quantitative",
        "title": "Total stops",
        "format": ",.0f"
      },
      {
        "field": "properties.Bus",
        "type": "quantitative",
        "title": "Bus stops",
        "format": ",.0f"
      },
      {
        "field": "properties.Train",
        "type": "quantitative",
        "title": "Train stops",
        "format": ",.0f"
      },
      {
        "field": "properties.Tram",
        "type": "quantitative",
        "title": "Tram stops",
        "format": ",.0f"
      },
      {
        "field": "properties.Regional",
        "type": "quantitative",
        "title": "Regional stops",
        "format": ",.0f"
      },
      {
        "field": "properties.AREASQKM21",
        "type": "quantitative",
        "title": "Area km²",
        "format": ",.1f"
      }
    ]
  },
  "config": {
    "font": "Source Sans 3, sans-serif",
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Source Sans 3, sans-serif",
      "titleFont": "Source Sans 3, sans-serif"
    },
    "legend": {
      "labelFont": "Source Sans 3, sans-serif",
      "titleFont": "Source Sans 3, sans-serif",
      "labelFontSize": 15,
      "titleFontSize": 16
    }
  }
}
