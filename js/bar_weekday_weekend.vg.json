{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": null,
  "width": "container",
  "height": 310,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "background": "transparent",
  "data": {
    "url": "data/weekday_weekend_patronage_2025.csv"
  },
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 2
  },
  "encoding": {
    "x": {
      "field": "mode_label",
      "type": "nominal",
      "title": null,
      "sort": [
        "Metro train",
        "Tram",
        "Metro bus",
        "Regional train",
        "Regional bus"
      ],
      "axis": {
        "labelAngle": -20,
        "labelLimit": 90
      }
    },
    "xOffset": {
      "field": "Day_type",
      "sort": [
        "Normal Weekday",
        "Weekend"
      ]
    },
    "y": {
      "field": "avg_daily_patronage_thousands",
      "type": "quantitative",
      "title": "Average daily patronage (thousands)",
      "axis": {
        "grid": true
      }
    },
    "color": {
      "field": "Day_type",
      "type": "nominal",
      "title": "Day type",
      "scale": {
        "domain": [
          "Normal Weekday",
          "Weekend"
        ],
        "range": [
          "#004B87",
          "#B8B4AA"
        ]
      }
    },
    "tooltip": [
      {
        "field": "mode_label",
        "type": "nominal",
        "title": "Mode"
      },
      {
        "field": "Day_type",
        "type": "nominal",
        "title": "Day type"
      },
      {
        "field": "avg_daily_patronage",
        "type": "quantitative",
        "title": "Average daily patronage",
        "format": ",.0f"
      },
      {
        "field": "avg_daily_patronage_thousands",
        "type": "quantitative",
        "title": "Thousands",
        "format": ".1f"
      }
    ]
  },
  "config": {
    "font": "Source Sans 3, sans-serif",
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Source Sans 3, sans-serif",
      "titleFont": "Source Sans 3, sans-serif",
      "labelFontSize": 11,
      "titleFontSize": 12,
      "gridColor": "#E8E4DB",
      "domainColor": "#9A968D",
      "tickColor": "#9A968D"
    },
    "legend": {
      "labelFont": "Source Sans 3, sans-serif",
      "titleFont": "Source Sans 3, sans-serif",
      "labelFontSize": 11,
      "titleFontSize": 12,
      "orient": "bottom",
      "direction": "horizontal"
    }
  }
}