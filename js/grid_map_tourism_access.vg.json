{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": null,
  "width": "container",
  "height": 320,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "background": "transparent",
  "data": {
    "url": "data/tourism_region_access.csv"
  },
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadiusEnd": 3
      },
      "encoding": {
        "x": {
          "field": "distance_km",
          "type": "quantitative",
          "title": "Distance to nearest regional train station (km)",
          "scale": {
            "domain": [
              0,
              55
            ],
            "zero": true
          },
          "axis": {
            "grid": true,
            "tickCount": 6
          }
        },
        "y": {
          "field": "region",
          "type": "nominal",
          "title": null,
          "sort": [
            "Phillip Island",
            "Grampians",
            "Great Ocean Road",
            "High Country",
            "Mornington Peninsula",
            "Yarra Valley and Dandenong Ranges",
            "Daylesford and Macedon Ranges",
            "Gippsland",
            "Murray",
            "Goldfields",
            "Geelong and the Bellarine",
            "Melbourne"
          ],
          "axis": {
            "labelLimit": 210,
            "labelPadding": 6
          }
        },
        "color": {
          "field": "access_category",
          "type": "nominal",
          "title": "Rail access",
          "scale": {
            "domain": [
              "Good",
              "Moderate",
              "Limited"
            ],
            "range": [
              "#0072B2",
              "#8D989D",
              "#D55E00"
            ]
          },
          "legend": {
            "orient": "bottom",
            "direction": "horizontal"
          }
        },
        "tooltip": [
          {
            "field": "region",
            "type": "nominal",
            "title": "Tourism region"
          },
          {
            "field": "nearest_station",
            "type": "nominal",
            "title": "Nearest station"
          },
          {
            "field": "distance_km",
            "type": "quantitative",
            "title": "Distance (km)",
            "format": ".1f"
          },
          {
            "field": "stations_within_50km",
            "type": "quantitative",
            "title": "Stations within 50 km",
            "format": ",.0f"
          },
          {
            "field": "stations_within_100km",
            "type": "quantitative",
            "title": "Stations within 100 km",
            "format": ",.0f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "rule",
        "stroke": "#9BA49F",
        "strokeDash": [
          5,
          4
        ],
        "strokeWidth": 1.2
      },
      "encoding": {
        "x": {
          "datum": 25
        }
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "bottom",
        "dx": 4,
        "dy": -4,
        "fontSize": 14,
        "color": "#667173"
      },
      "encoding": {
        "x": {
          "datum": 25
        },
        "y": {
          "datum": "Phillip Island"
        },
        "text": {
          "value": "25 km reference"
        }
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 5,
        "fontSize": 14,
        "fontWeight": 600,
        "color": "#1F2728"
      },
      "encoding": {
        "x": {
          "field": "distance_km",
          "type": "quantitative"
        },
        "y": {
          "field": "region",
          "type": "nominal",
          "sort": [
            "Phillip Island",
            "Grampians",
            "Great Ocean Road",
            "High Country",
            "Mornington Peninsula",
            "Yarra Valley and Dandenong Ranges",
            "Daylesford and Macedon Ranges",
            "Gippsland",
            "Murray",
            "Goldfields",
            "Geelong and the Bellarine",
            "Melbourne"
          ]
        },
        "text": {
          "field": "distance_label",
          "type": "nominal"
        }
      },
      "transform": [
        {
          "calculate": "format(datum.distance_km, '.1f') + ' km'",
          "as": "distance_label"
        }
      ]
    }
  ],
  "config": {
    "font": "Source Sans 3, sans-serif",
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Source Sans 3, sans-serif",
      "titleFont": "Source Sans 3, sans-serif",
      "labelFontSize": 15,
      "titleFontSize": 16,
      "gridColor": "#E3E8E4",
      "domainColor": "#A8B0AC",
      "tickColor": "#A8B0AC",
      "labelColor": "#1F2728",
      "titleColor": "#1F2728"
    },
    "legend": {
      "labelFont": "Source Sans 3, sans-serif",
      "titleFont": "Source Sans 3, sans-serif",
      "labelFontSize": 15,
      "titleFontSize": 16
    }
  }
}
