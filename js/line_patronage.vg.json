{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": null,
  "width": "container",
  "height": 340,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "background": "transparent",
  "data": {
    "url": "data/monthly_patronage_long.csv"
  },
  "transform": [
    {
      "filter": "indexof(['Metropolitan train','Metropolitan tram','Metropolitan bus','Regional train'], datum.mode) >= 0"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "line",
        "strokeWidth": 2.2,
        "opacity": 0.9
      },
      "encoding": {
        "x": {
          "field": "date",
          "type": "temporal",
          "title": "Month",
          "axis": {
            "format": "%Y",
            "labelAngle": 0,
            "grid": false
          }
        },
        "y": {
          "field": "patronage_millions",
          "type": "quantitative",
          "title": "Monthly patronage (millions)",
          "axis": {
            "grid": true
          }
        },
        "color": {
          "field": "mode",
          "type": "nominal",
          "title": "Mode",
          "scale": {
            "domain": [
              "Metropolitan train",
              "Metropolitan tram",
              "Metropolitan bus",
              "Regional train"
            ],
            "range": [
              "#0072B2",
              "#CC79A7",
              "#D55E00",
              "#8D989D"
            ]
          }
        },
        "strokeDash": {
          "field": "mode",
          "type": "nominal",
          "scale": {
            "domain": [
              "Metropolitan train",
              "Metropolitan tram",
              "Metropolitan bus",
              "Regional train"
            ],
            "range": [
              [],
              [
                6,
                3
              ],
              [
                2,
                3
              ],
              [
                9,
                3
              ]
            ]
          }
        },
        "tooltip": [
          {
            "field": "Month name",
            "type": "nominal",
            "title": "Month"
          },
          {
            "field": "Year",
            "type": "ordinal",
            "title": "Year"
          },
          {
            "field": "mode",
            "type": "nominal",
            "title": "Mode"
          },
          {
            "field": "patronage_millions",
            "type": "quantitative",
            "title": "Patronage (millions)",
            "format": ".2f"
          },
          {
            "field": "patronage",
            "type": "quantitative",
            "title": "Patronage",
            "format": ",.0f"
          }
        ]
      }
    },
    {
      "data": {
        "values": [
          {
            "date": "2020-04-01",
            "label": "2020 disruption"
          },
          {
            "date": "2021-10-01",
            "label": "reopening period"
          },
          {
            "date": "2023-03-01",
            "label": "fare policy shift"
          }
        ]
      },
      "mark": {
        "type": "rule",
        "stroke": "#A8B0AC",
        "strokeDash": [
          4,
          4
        ],
        "opacity": 0.55
      },
      "encoding": {
        "x": {
          "field": "date",
          "type": "temporal"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "date": "2020-04-01",
            "patronage_millions": 24,
            "label": "2020 disruption"
          },
          {
            "date": "2021-10-01",
            "patronage_millions": 22,
            "label": "reopening"
          },
          {
            "date": "2023-03-01",
            "patronage_millions": 20,
            "label": "fare shift"
          }
        ]
      },
      "mark": {
        "type": "text",
        "angle": 270,
        "align": "right",
        "baseline": "middle",
        "dx": -4,
        "font": "Source Sans 3, sans-serif",
        "fontSize": 14,
        "color": "#596265"
      },
      "encoding": {
        "x": {
          "field": "date",
          "type": "temporal"
        },
        "y": {
          "field": "patronage_millions",
          "type": "quantitative"
        },
        "text": {
          "field": "label"
        }
      }
    }
  ],
  "config": {
    "font": "Source Sans 3, sans-serif",
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Source Sans 3, sans-serif",
      "titleFont": "Source Sans 3, sans-serif",
      "labelFontSize": 15,
      "titleFontSize": 16,
      "gridColor": "#E3E8E4",
      "domainColor": "#A8B0AC",
      "tickColor": "#A8B0AC"
    },
    "legend": {
      "labelFont": "Source Sans 3, sans-serif",
      "titleFont": "Source Sans 3, sans-serif",
      "labelFontSize": 15,
      "titleFontSize": 16,
      "orient": "bottom",
      "direction": "horizontal"
    }
  }
}
